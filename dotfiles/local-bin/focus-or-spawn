#!/usr/bin/env bash
# Focus an existing window matching APP_ID_REGEX, or spawn the given command.
#
# Usage: focus-or-spawn <app_id_regex> <cmd> [args...]
#
# Picks the most recently focused matching window (by focus_timestamp),
# which keeps Mod+Shift+W on the main WhatsApp window even if a transient
# popup (call, picker) shares the same app_id.
#
# niri-only: relies on `niri msg -j windows` and `niri msg action focus-window`.

set -u

if [ "$#" -lt 2 ]; then
    echo "usage: $(basename "$0") <app_id_regex> <cmd> [args...]" >&2
    exit 2
fi

regex="$1"
shift

if niri msg version >/dev/null 2>&1; then
    id=$(niri msg -j windows 2>/dev/null | jq -r --arg re "$regex" '
        map(select((.app_id // "") | test($re)))
        | sort_by(-(.focus_timestamp.secs // 0))
        | (.[0].id // empty)
    ')
    if [ -n "${id:-}" ]; then
        niri msg action focus-window --id "$id" >/dev/null 2>&1
        exit 0
    fi
fi

exec "$@"

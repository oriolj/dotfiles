#!/usr/bin/env python3
"""Combine `claude-usage --waybar` and `codex-usage --waybar` into one
Noctalia CustomButton (parseJson: true) widget.

Bar text:  "{claude_pct}% {codex_pct}% {claude_reset}"  — only Claude's
           5h reset time is shown, since both tools have similar windows
           and the bar has limited width.
Tooltip:   Claude tooltip, blank line, Codex tooltip — full detail.
textColor: based on the higher of the two 5h percentages (error if a
           tool needs login).

Both tools are passive cookie readers: they read the claude.ai / chatgpt.com
session cookie out of the browser's cookie DB and call the usage API. A
401/403 ("Auth Err") means that cookie is stale. The only thing that
refreshes it is the browser loading the site (rotating the cookie back into
the DB), so on Auth Err we open the site in its browser to try to renew —
but at most MAX_ATTEMPTS times, spaced COOLDOWN seconds apart. After that we
stop opening (so we don't spawn a tab on every poll) and show 🔑 with the
browser to open, until a successful read resets the counter.

A no-op xdg-open shim is kept on PATH so the tools' own unbounded login-page
launches never fire; the bounded opens below are the only intended ones.
"""
from __future__ import annotations

import json
import os
import pathlib
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor

MAX_ATTEMPTS = 3
COOLDOWN = 25  # seconds between renew attempts, so the cookie has time to refresh

PROVIDERS = {
    "claude": {
        "title": "Claude Code",
        "browser": "chromium",
        "label": "Chromium",
        "url": "https://claude.ai",
        "state": "/tmp/claude-usage-noctalia.claude.auth",
    },
    "codex": {
        "title": "Codex",
        "browser": "brave",
        "label": "Brave",
        "url": "https://chatgpt.com",
        "state": "/tmp/claude-usage-noctalia.codex.auth",
    },
}


def install_noop_xdg_open() -> None:
    """Shadow `xdg-open` with a no-op so the usage tools can't launch a
    browser on their own; the bounded opens in this script are the only
    intended launches. Affects this process and its children."""
    shim_dir = pathlib.Path("/tmp/claude-usage-noctalia-shim")
    shim = shim_dir / "xdg-open"
    if not shim.exists():
        shim_dir.mkdir(parents=True, exist_ok=True)
        shim.write_text("#!/bin/sh\nexit 0\n")
        shim.chmod(0o755)
    os.environ["PATH"] = f"{shim_dir}:{os.environ.get('PATH', '')}"


def color_for(percentage: int) -> str:
    if percentage <= 15:
        return "none"
    if percentage <= 50:
        return "tertiary"
    if percentage <= 80:
        return "primary"
    return "error"


def fetch(cmd: list[str]) -> dict | None:
    try:
        raw = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        sys.stderr.write(f"{cmd[0]} failed: {exc}\n")
        return None
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return None


def pct(data: dict | None) -> int:
    return int(data.get("percentage", 0)) if data else 0


def is_error(data: dict | None) -> bool:
    return bool(data) and data.get("class") == "critical"


def is_auth_error(data: dict | None) -> bool:
    return is_error(data) and "Auth Err" in data.get("text", "")


def read_state(path: str) -> tuple[int, float]:
    """(attempt_count, last_attempt_epoch); (0, 0) if no state yet."""
    try:
        n, ts = pathlib.Path(path).read_text().split()
        return int(n), float(ts)
    except Exception:
        return 0, 0.0


def write_state(path: str, n: int, ts: float) -> None:
    pathlib.Path(path).write_text(f"{n} {ts}")


def open_browser(browser: str, url: str) -> None:
    try:
        subprocess.Popen(
            [browser, url],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except FileNotFoundError:
        pass


def handle(name: str, data: dict | None, now: float) -> tuple[str, str, bool]:
    """Return (bar_segment, tooltip_segment, needs_login). Performs the
    bounded renew side-effects for auth errors."""
    cfg = PROVIDERS[name]

    if data is None:
        return "·", f"{cfg['title']}\n(unavailable)", False

    if is_auth_error(data):
        n, ts = read_state(cfg["state"])
        if n >= MAX_ATTEMPTS:
            tip = (f"{cfg['title']}\n🔑 login needed — open {cfg['label']} and "
                   f"sign in at {cfg['url']}, then it refreshes automatically")
            return "🔑", tip, True
        if now - ts >= COOLDOWN:
            n += 1
            write_state(cfg["state"], n, now)
            open_browser(cfg["browser"], cfg["url"])
        tip = f"{cfg['title']}\n🔄 renewing login in {cfg['label']} ({n}/{MAX_ATTEMPTS})…"
        return "🔄", tip, False

    if is_error(data):
        return "⚠", f"{cfg['title']}\n{data.get('tooltip', '')}", False

    # Success — clear any auth-failure state.
    pathlib.Path(cfg["state"]).unlink(missing_ok=True)
    return f"{pct(data)}%", f"{cfg['title']}\n{data.get('tooltip', '')}", False


def main() -> int:
    install_noop_xdg_open()
    now = time.time()

    # --format '{reset}' makes each tool's JSON `text` field just the reset
    # string (no pango), so we can read it directly without a regex strip.
    cmds = [
        ["claude-usage", "--waybar", "--browser", PROVIDERS["claude"]["browser"], "--format", "{reset}"],
        ["codex-usage", "--waybar", "--browser", PROVIDERS["codex"]["browser"], "--format", "{reset}"],
    ]
    with ThreadPoolExecutor(max_workers=2) as ex:
        claude, codex = list(ex.map(fetch, cmds))

    if claude is None and codex is None:
        print(json.dumps({"text": "", "tooltip": ""}))
        return 0

    claude_bar, claude_tip, claude_login = handle("claude", claude, now)
    codex_bar, codex_tip, codex_login = handle("codex", codex, now)

    bits = [claude_bar, codex_bar]
    # Show Claude's 5h reset only when it actually fetched OK.
    if claude and not is_error(claude):
        claude_reset = claude.get("text", "")
        if claude_reset:
            bits.append(claude_reset)
    text = " ".join(bits)

    tooltip = f"{claude_tip}\n\n{codex_tip}"

    if claude_login or codex_login:
        text_color = "error"
    else:
        text_color = color_for(max(pct(claude), pct(codex)))

    print(json.dumps({
        "text": text,
        "tooltip": tooltip,
        "textColor": text_color,
    }))
    return 0


if __name__ == "__main__":
    sys.exit(main())

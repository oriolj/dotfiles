#!/usr/bin/env python3
"""Combine `claude-usage --waybar` and `codex-usage --waybar` into one
Noctalia CustomButton (parseJson: true) widget.

Bar text:  "{claude_pct}% {codex_pct}% {claude_reset}"  — only Claude's
           5h reset time is shown, since both tools have similar windows
           and the bar has limited width.
Tooltip:   Claude tooltip, blank line, Codex tooltip — full detail.
textColor: based on the higher of the two 5h percentages.
"""
from __future__ import annotations

import json
import re
import subprocess
import sys

PANGO_SPAN = re.compile(r"<[^>]+>")


def color_for(percentage: int) -> str:
    if percentage <= 15:
        return "none"
    if percentage <= 50:
        return "tertiary"
    if percentage <= 80:
        return "primary"
    return "error"


def fetch(cmd: list[str]) -> dict | None:
    try:
        raw = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        sys.stderr.write(f"{cmd[0]} failed: {exc}\n")
        return None
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return None


def reset_from_text(data: dict) -> str:
    # waybar text format: "{icon} {pct}% {clock_icon} {reset}" with pango spans.
    plain = PANGO_SPAN.sub("", data.get("text", "")).strip()
    parts = plain.split()
    return parts[-1] if parts else ""


def pct(data: dict) -> int:
    try:
        return int(data.get("percentage", 0))
    except (TypeError, ValueError):
        return 0


def main() -> int:
    claude = fetch(["claude-usage", "--waybar", "--browser", "chromium"])
    codex = fetch(["codex-usage", "--waybar", "--browser", "chromium"])

    if claude is None and codex is None:
        print(json.dumps({"text": "", "tooltip": ""}))
        return 0

    claude_pct = pct(claude) if claude else 0
    codex_pct = pct(codex) if codex else 0
    claude_reset = reset_from_text(claude) if claude else ""

    bits = [f"{claude_pct}%", f"{codex_pct}%"]
    if claude_reset:
        bits.append(claude_reset)
    text = " ".join(bits)

    tooltip_parts = []
    if claude:
        tooltip_parts.append("Claude Code\n" + claude.get("tooltip", ""))
    if codex:
        tooltip_parts.append("Codex\n" + codex.get("tooltip", ""))
    tooltip = "\n\n".join(tooltip_parts)

    color = color_for(max(claude_pct, codex_pct))

    print(json.dumps({"text": text, "tooltip": tooltip, "textColor": color}))
    return 0


if __name__ == "__main__":
    sys.exit(main())

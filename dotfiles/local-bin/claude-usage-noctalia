#!/usr/bin/env python3
"""Wrap `claude-usage --waybar` output for the Noctalia bar's CustomButton widget.

Waybar's pango-marked-up text and CSS class names don't translate, so this
script reshapes the JSON: strips pango spans, picks a Noctalia theme colour
based on the usage tier, and keeps the multi-line tooltip intact.

Output JSON keys consumed by Noctalia's CustomButton (parseJson: true):
  text       -- plain text shown in the bar (no pango)
  icon       -- single character / nerd-font glyph rendered as the widget icon
  tooltip    -- shown on hover
  iconColor  -- one of: primary, secondary, tertiary, error, none
  textColor  -- same vocabulary
"""
from __future__ import annotations

import json
import re
import subprocess
import sys

PANGO_SPAN = re.compile(r"<[^>]+>")


# Pick a Noctalia colour token by 5-hour usage percentage. Noctalia's
# CustomButton only accepts primary/secondary/tertiary/error/none — there's no
# real green/yellow in the default palette, so this is the closest substitute:
# none (~white) → tertiary (light purple, "green") → primary (light blue,
# "yellow") → error (red).
def color_for(percentage: int) -> str:
    if percentage <= 15:
        return "none"
    if percentage <= 50:
        return "tertiary"
    if percentage <= 80:
        return "primary"
    return "error"

def main() -> int:
    try:
        raw = subprocess.check_output(
            ["claude-usage", "--waybar", "--browser", "chromium"],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        sys.stderr.write(f"claude-usage failed: {exc}\n")
        # Empty output collapses the widget.
        print(json.dumps({"text": "", "tooltip": ""}))
        return 0

    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        print(json.dumps({"text": "", "tooltip": ""}))
        return 0

    text_in = data.get("text", "")
    text_plain = PANGO_SPAN.sub("", text_in).strip()
    tooltip = data.get("tooltip", "")
    try:
        percentage = int(data.get("percentage", 0))
    except (TypeError, ValueError):
        percentage = 0
    color = color_for(percentage)

    print(
        json.dumps(
            {
                "text": text_plain,
                "tooltip": tooltip,
                "textColor": color,
            }
        )
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
